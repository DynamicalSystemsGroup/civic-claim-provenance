# Local Flexo stack in Docker (openmbee/flexo-mms-deployment) — the default.
# NO token needed: the auth service issues one from user01/password1 via /login.
# These match the CLI defaults, so even an empty .env works once Docker is up.
FLEXO_URL=http://localhost:8080
FLEXO_AUTH_URL=http://localhost:8082
FLEXO_USER=user01
FLEXO_PASS=password1
FLEXO_ORG=civic
FLEXO_REPO=composting
FLEXO_BRANCH=main

# Hosted remote alternative (this is the ONLY path that needs a pre-issued token):
# FLEXO_URL=https://try-layer1.starforge.app
# FLEXO_TOKEN=eyJhbGci...
# (when FLEXO_TOKEN is set, the login flow is skipped)
